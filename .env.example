# Public client-side Supabase keys (safe to expose in browser)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional Vite-style aliases supported by src/lib/supabase.ts
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Server-only (DO NOT COMMIT REAL VALUES)
# Enables server routes that upsert/read data without user auth in local dev
SUPABASE_SERVICE_ROLE_KEY=

# LLM providers (server)
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
GROQ_API_KEY=

# Development-only convenience
# Set to "true" to bypass auth in local Admin UI
NEXT_PUBLIC_DEV_NO_AUTH=
